{
  "name": "adxstudio",
  "version": "1.0.7",
  "description": "ADXStudio",
  "main": "app/main.js",
  "scripts": {
    "start": "electron --enable-logging --inspect=9229 ./app/main.js",
    "test": "jasmine-node spec/",
    "dist": "electron-builder --win --x64 --ia32"
