  "repository": {
    "type": "git",
    "url": "git+https://github.com/AskiaADX/ADXStudio.git"
  },
  "keywords": [
    "ADX",
    "ADC",
    "ADP",
    "ASX",
    "AskiaScript",
    "ASKIA",
    "Design",
    "Control",
    "Page"
  ],
  "author": "Askia SAS",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AskiaADX/ADXStudio/issues"
  },
  "homepage": "https://github.com/AskiaADX/ADXStudio",
  "dependencies": {
    "@node-minify/core": "^10.5.0",
    "@node-minify/uglify-js": "^10.5.0",
    "axios": "^1.15.2",
    "charset-detector": "0.0.2",
    "cli-color": "^2.0.4",
    "commander": "^14.0.3",
    "elementtree": "^0.1.7",
    "fs.extra": "^1.3.2",
    "glob": "^11.0.0",
    "jszip": "^3.10.1",
    "mime-types": "^2.1.27",
    "minimist": "^1.2.8",
    "ncp": "^2.0.0",
    "node-zendesk": "^6.0.1",
    "nodejs-websocket": "^1.7.2",
    "request": "^2.88.2",
    "uuid": "^14.0.0",
    "wrench": "^1.5.9"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "ini": "^6.0.0",
    "jasmine-node": "^3.0.0",
    "underscore": "^1.13.8",
    "yargs-parser": ">=5.0.0-security.0"
  },
  "build": {
    "appId": "com.askia.adxstudio",
    "asar": false,
    "buildVersion": "0",
    "electronVersion": "41.3.0",
    "copyright": "Copyright (c) Askia 2026",
    "productName": "ADXStudio",
    "win": {
      "target": "nsis",
